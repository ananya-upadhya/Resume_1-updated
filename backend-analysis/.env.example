PROJECT_NAME="Resume Intelligence API"
VERSION="0.1.0"
API_V1_STR="/api/v1"

# LLM Configuration
USE_LLM=true
LLM_PROVIDER="groq"
LLM_MODEL="llama-3.3-70b-versatile"

